# MODECT voice-bridge — variables d'environnement

# OpenAI Realtime
OPENAI_API_KEY=sk-proj-...

# Twilio (compte upgradé, sortant FR/intl autorisé)
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_NUMBER=+33939035269

# Origines autorisées pour CORS (séparées par virgule).
# En prod : https://www.modect.com,https://modect.com
# En dev local : http://localhost:5173
ALLOWED_ORIGINS=https://www.modect.com,https://modect.com

# Port (Render le fournit automatiquement ; 5050 en local)
PORT=5050

# Durée max d'un appel démo (en secondes) — coupure serveur de sécurité.
# 120 = 2 min. Au-delà, on raccroche pour limiter le coût des démos.
MAX_CALL_SECONDS=120

# Durée max d'un appel planifié Modect (en secondes). 900 = 15 min.
MAX_SCHEDULED_CALL_SECONDS=900

# Sonnerie max Twilio pour un appel planifié avant raccrochage automatique.
# Au-delà, c'est la passe B (no-answer) de schedule-calls qui prend le relais.
SCHEDULED_RING_TIMEOUT=30

# Supabase — pour écrire les rows dans demo_calls (tracking /track_calls)
# ET dans calls (appels planifiés Modect via /scheduled-call).
# Si NON renseignées, le service tourne quand même mais ne persiste rien.
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# Auth interne Supabase ↔ voice-bridge pour les appels planifiés.
# Doit être identique au secret MODECT_INTERNAL_TOKEN côté Supabase.
# Générer une chaîne longue aléatoire (ex: `openssl rand -hex 32`).
# Si absent → /scheduled-call refusé en 503.
MODECT_INTERNAL_TOKEN=...
