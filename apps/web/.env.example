# MODECT — app unique (vitrine + back-office)

# Supabase (back-office)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=        # clé publique anon
VITE_APP_URL=https://app.modect.com

# Cible des CTA Connexion / Créer un compte de la vitrine.
# Prod : https://app.modect.com (bascule vers le sous-domaine back-office).
# Local : laisser VIDE → liens relatifs sur la même origine (localhost:5173).
VITE_DASHBOARD_URL=https://app.modect.com

# Service voice-bridge (démo téléphone vitrine) — hébergé sur Render.
# Prod : https://voice.modect.com (ou l'URL Render onrender.com directe).
# Local : laisser VIDE pour cacher le bouton "Me faire appeler" en dev.
VITE_VOICE_BRIDGE_URL=https://voice.modect.com
