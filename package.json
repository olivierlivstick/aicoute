{
  "name": "modect",
  "version": "0.1.0",
  "private": true,
  "description": "Monorepo MODECT — app web unique (vitrine + back-office) dans apps/web, app mobile dans apps/mobile",
  "scripts": {
    "dev": "npm --prefix apps/web run dev",
    "build": "npm --prefix apps/web run build",
    "preview": "npm --prefix apps/web run preview",
    "typecheck": "npm --prefix apps/web run typecheck",
    "install:all": "npm --prefix apps/web install",
    "test:email-report": "node scripts/test-email-report.mjs"
  }
}
